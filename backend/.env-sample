ENVIRONMENT=localhost
POSTGRES_USER=finances
POSTGRES_DB_AUTH=finances_auth
POSTGRES_DB_AUDIT=finances_audit
POSTGRES_DB_MARKET=finances_market
POSTGRES_DB_USER=finances_user
JWT_EXPIRY_H=168

# random uuid
POSTGRES_PASSWORD="" # <---------------- Preenche entre as aspas.

# random uuid
JWT_SECRET="" # <---------------- Preenche entre as aspas.

# random uuid
APP_SECRET="" # <---------------- Preenche entre as aspas.

# random md5
ENCRYPTION_KEY="" # <---------------- Preenche entre as aspas.
ENCRYPTION_KEY_DB="" # <---------------- Preenche entre as aspas.

AUTH_DB_TYPE=postgres
AUTH_DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB_AUTH}
AUDIT_DB_TYPE=postgres
AUDIT_DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB_AUDIT}
MARKET_DB_TYPE=postgres
MARKET_DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB_MARKET}

DEFAULT_USER_DB_TYPE=postgres
DEFAULT_USER_DB=${POSTGRES_DB_USER}
DEFAULT_USER_DB_DNS=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/postgres



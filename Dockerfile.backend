FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY backend/app.py backend/database.py backend/auth_db.py backend/parsers.py backend/seed.py ./

# Ensure the dbs directory exists inside the container
RUN mkdir -p /app/data

EXPOSE 5001

CMD ["python", "-u", "app.py"]
